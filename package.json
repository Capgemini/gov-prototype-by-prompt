{
    "name": "gov-prototype-by-prompt",
    "version": "3.0.0",
    "description": "Rapidly create, test, and refine GOV.UK Design System form prototypes from a simple description using GenAI.",
    "keywords": [
        "express",
        "generative-ai",
        "govuk",
        "nodejs",
        "nunjucks",
        "prototyping",
        "typescript",
        "user-research",
        "ux-design"
    ],
    "homepage": "https://github.com/Capgemini/gov-prototype-by-prompt",
    "bugs": {
        "url": "https://github.com/Capgemini/gov-prototype-by-prompt/issues"
    },
    "license": "MIT",
    "author": "Digital Excellence Lab, Capgemini Invent UK",
    "contributors": [
        "Bilal Mahmood",
        "Chris Currie",
        "Christopher Menon",
        "Dragos-Andrei Ilies",
        "George Herbert",
        "Jag Gill",
        "Jake Readman",
        "Rahmat Junaid",
        "Rosie Kelly",
        "Ryan Smith",
        "Sam West",
        "Steven Tran",
        "Toba Odumosu"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Capgemini/gov-prototype-by-prompt.git"
    },
    "engines": {
        "node": ">=22.22.3 <23.0.0",
        "npm": ">=11.6.4 <12.0.0"
    },
    "packageManager": "npm@11.6.4",
    "scripts": {
        "start": "npx --yes tsx --import ./src/instrumentation.ts server.ts",
        "dev": "tsx watch ./server.ts",
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "jest --config=./config/jest/jest.config.ts",
        "test:e2e": "npx playwright test --config ./config/playwright/playwright.config.ts",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "db:start": "docker-compose up -d",
        "db:stop": "docker-compose down",
        "db:reset": "docker-compose down -v && docker-compose up -d",
        "evals": "jest --config=evals/jest.config.ts"
    },
    "dependencies": {
        "@azure/monitor-opentelemetry-exporter": "~1.0.0-beta.32",
        "@opentelemetry/api": "~1.9.1",
        "@opentelemetry/auto-instrumentations-node": "~0.78.0",
        "@opentelemetry/instrumentation-express": "~0.68.0",
        "@opentelemetry/instrumentation-http": "~0.220.0",
        "@opentelemetry/sdk-metrics": "~2.9.0",
        "@opentelemetry/sdk-node": "~0.220.0",
        "@opentelemetry/sdk-trace-node": "~2.9.0",
        "ace-builds": "~1.44.0",
        "ace-linters": "~2.2.0",
        "bcryptjs": "~3.0.3",
        "body-parser": "~2.3.0",
        "client-zip": "~2.5.0",
        "compression": "~1.8.1",
        "dotenv": "~17.4.2",
        "express": "~5.2.1",
        "express-rate-limit": "~8.5.2",
        "express-session": "~1.19.0",
        "express-validator": "~7.3.2",
        "govuk-frontend": "~6.3.0",
        "govuk-markdown": "~0.8.0",
        "helmet": "~8.2.0",
        "hmrc-frontend": "~7.23.0",
        "html-format": "~1.1.7",
        "jsonschema": "~1.5.0",
        "marked": "~17.0.6",
        "mermaid": "~11.16.0",
        "moment": "~2.30.1",
        "mongoose": "~9.7.3",
        "nunjucks": "~3.2.4",
        "openai": "~6.45.0",
        "ts-migrate-mongoose": "~5.3.3",
        "tsx": "~4.23.0",
        "zod": "~4.4.3"
    },
    "devDependencies": {
        "@cspell/dict-en-gb": "~5.0.29",
        "@cspell/eslint-plugin": "~10.0.1",
        "@eslint/js": "~10.0.1",
        "@playwright/test": "~1.61.1",
        "@types/body-parser": "~1.19.6",
        "@types/compression": "~1.8.1",
        "@types/express": "~5.0.6",
        "@types/express-session": "~1.19.0",
        "@types/jest": "~30.0.0",
        "@types/node": "^22.13.4",
        "@types/nunjucks": "~3.2.6",
        "@types/supertest": "~7.2.0",
        "cspell": "~10.0.1",
        "eslint": "~10.6.0",
        "eslint-config-prettier": "~10.1.8",
        "eslint-plugin-only-warn": "~1.2.1",
        "eslint-plugin-perfectionist": "~5.9.1",
        "jest": "~30.4.2",
        "jiti": "~2.7.0",
        "mongodb-memory-server": "~11.2.0",
        "node-mocks-http": "~1.17.2",
        "nodemon": "~3.1.14",
        "prettier": "~3.9.4",
        "supertest": "~7.2.2",
        "ts-jest": "~29.4.11",
        "ts-node": "~10.9.2",
        "typescript": "~5.9.3",
        "typescript-eslint": "~8.62.1",
        "undici": "~7.28.0"
    }
}
